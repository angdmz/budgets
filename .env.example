# Database Configuration
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=budgets
DB_PORT=5432

# API Configuration
API_PORT=8080
SERVER_ENV=development

# Security - REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT Secret - Change in production
JWT_SECRET=change-me-in-production

# Auth0 Configuration - REQUIRED
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.budget.local
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Auth0 Management API (M2M) - for integration tests user lifecycle
AUTH0_MGMT_CLIENT_ID=your-auth0-m2m-client-id
AUTH0_MGMT_CLIENT_SECRET=your-auth0-m2m-client-secret
AUTH0_DB_CONNECTION=Username-Password-Authentication

# Secrets Provider: env, docker, aws, localstack
SECRETS_PROVIDER=env

# Integration tests
INTEGRATION_TESTS_BASE_URL=http://nginx
INTEGRATION_TESTS_SCREENSHOTS_DIR=/tests/screenshots
INTEGRATION_TESTS_SCREENSHOTS_HOST_DIR=./tests/screenshots
INTEGRATION_TESTS_SECRETS_PROVIDER=docker