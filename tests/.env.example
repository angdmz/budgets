# Test Configuration
TEST_BASE_URL=http://localhost:8000

# Auth0 Management API (M2M) - for dynamic test user creation/deletion
# Create a Machine-to-Machine app in Auth0 Dashboard, authorize it for the
# Management API with create:users and delete:users scopes.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_MGMT_CLIENT_ID=your-auth0-m2m-client-id
AUTH0_MGMT_CLIENT_SECRET=your-auth0-m2m-client-secret
AUTH0_DB_CONNECTION=Username-Password-Authentication
